# Application Configuration
AGENTS_RELOAD=True
AGENTS_OPENTELEMETRY_ENDPOINT=http://localhost:4317
AGENTS_RUST_ENDPOINT=http://localhost:8000

# Database Configuration
AGENTS_DATABASE_HOST=localhost
AGENTS_DATABASE_NAME=insta_dash
AGENTS_DATABASE_PORT=5432
AGENTS_DATABASE_USERNAME=postgres
AGENTS_DATABASE_PASSWORD=password
AGENTS_DATABASE_REQUIRE_SSL=false

# External API Keys
AGENTS_MISTRAL_API_KEY=api_key_here
AGENTS_OPENROUTER_API_KEY=api_key_here
AGENTS_GOOGLE_API_KEY=api_key_here
AGENTS_GROQ_API_KEY=api_key_here

# Qdrant Vector Database Configuration
AGENTS_QDRANT_URL=http://127.0.0.1:6333
AGENTS_QDRANT_LOCAL_PATH=.qdrant_data
AGENTS_QDRANT_COLLECTION_PREFIX=assurance
AGENTS_QDRANT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
AGENTS_QDRANT_DEFAULT_LIMIT=6

# Langfuse Configuration
AGENTS_LANGFUSE_SECRET_KEY=api_key_here
AGENTS_LANGFUSE_PUBLIC_KEY=api_key_here
AGENTS_LANGFUSE_BASE_URL="https://cloud.langfuse.com"
